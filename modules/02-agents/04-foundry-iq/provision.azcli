#!/usr/bin/env bash
# Provision Azure resources for the 04-foundry-iq demo (Fabrikam Audio)
# Run from any directory — paths are resolved relative to this script.
# After running, run provision-foundry.azcli to create the knowledge source,
# knowledge base, MCP connection, and the agent wired to the knowledge base.
set -euo pipefail

SUBSCRIPTION="cd091145-5ea2-4703-ba5d-41063b1d4308"
RESOURCE_GROUP="rg-ai-103"
LOCATION="swedencentral"
SEARCH_NAME="ai103demossearch"
STORAGE_NAME="ai103demosstorage"
CONTAINER="fabrikam-audio"
FOUNDRY_ACCOUNT="ai-103-demos-resource"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ASSETS_DIR="${SCRIPT_DIR}/assets"
DEPLOY_CONFIG="${SCRIPT_DIR}/../../../.claude/deploy.config"

az account set --subscription "$SUBSCRIPTION"

echo "==> Creating AI Search (free tier)..."
az search service create \
  --name "$SEARCH_NAME" \
  --resource-group "$RESOURCE_GROUP" \
  --sku free \
  --location "$LOCATION" \
  --output none 2>/dev/null || echo "    already exists"

az search service update \
  --name "$SEARCH_NAME" \
  --resource-group "$RESOURCE_GROUP" \
  --auth-options aadOrApiKey \
  --aad-auth-failure-mode http401WithBearerChallenge \
  --output none

SEARCH_KEY=$(az search admin-key show \
  --service-name "$SEARCH_NAME" \
  --resource-group "$RESOURCE_GROUP" \
  --query "primaryKey" -o tsv)

SEARCH_ENDPOINT="https://${SEARCH_NAME}.search.windows.net"

echo "==> Creating storage account..."
az storage account create \
  --name "$STORAGE_NAME" \
  --resource-group "$RESOURCE_GROUP" \
  --location "$LOCATION" \
  --sku Standard_LRS \
  --kind StorageV2 \
  --output none 2>/dev/null || echo "    already exists"

STORAGE_KEY=$(az storage account keys list \
  --account-name "$STORAGE_NAME" \
  --resource-group "$RESOURCE_GROUP" \
  --query "[0].value" -o tsv)

echo "==> Creating blob container and uploading assets..."
az storage container create \
  --name "$CONTAINER" \
  --account-name "$STORAGE_NAME" \
  --account-key "$STORAGE_KEY" \
  --output none

az storage blob upload-batch \
  --account-name "$STORAGE_NAME" \
  --account-key "$STORAGE_KEY" \
  --destination "$CONTAINER" \
  --source "$ASSETS_DIR" \
  --overwrite \
  --output none

echo "==> Assigning RBAC roles to Foundry managed identity..."
PRINCIPAL=$(az cognitiveservices account show \
  --name "$FOUNDRY_ACCOUNT" \
  --resource-group "$RESOURCE_GROUP" \
  --query "identity.principalId" -o tsv)

SEARCH_SCOPE="/subscriptions/${SUBSCRIPTION}/resourceGroups/${RESOURCE_GROUP}/providers/Microsoft.Search/searchServices/${SEARCH_NAME}"

az role assignment create \
  --role "Search Index Data Contributor" \
  --assignee-object-id "$PRINCIPAL" \
  --assignee-principal-type ServicePrincipal \
  --scope "$SEARCH_SCOPE" \
  --output none 2>/dev/null || echo "    Search Index Data Contributor already assigned"

az role assignment create \
  --role "Search Service Contributor" \
  --assignee-object-id "$PRINCIPAL" \
  --assignee-principal-type ServicePrincipal \
  --scope "$SEARCH_SCOPE" \
  --output none 2>/dev/null || echo "    Search Service Contributor already assigned"

echo "==> Writing AI Search credentials to deploy.config..."
if ! grep -q "AZURE_AI_SEARCH_ENDPOINT" "$DEPLOY_CONFIG"; then
  printf "\nAZURE_AI_PROJECT_ENDPOINT=https://ai-103-demos-resource.services.ai.azure.com/api/projects/ai-103-demos\n" >> "$DEPLOY_CONFIG"
  printf "AZURE_AI_SEARCH_ENDPOINT=%s\n" "$SEARCH_ENDPOINT" >> "$DEPLOY_CONFIG"
  printf "AZURE_AI_SEARCH_API_KEY=%s\n" "$SEARCH_KEY" >> "$DEPLOY_CONFIG"
  echo "    written"
else
  echo "    already present"
fi

echo ""
echo "Done."
echo "  AI Search : ${SEARCH_ENDPOINT}"
echo "  Storage   : https://${STORAGE_NAME}.blob.core.windows.net/${CONTAINER}/"
echo ""
echo "Next steps:"
echo "  1. Run ./provision-foundry.azcli to create the knowledge base and the agent."
echo "  2. Confirm the knowledge source reaches 'active' in the Foundry portal."
