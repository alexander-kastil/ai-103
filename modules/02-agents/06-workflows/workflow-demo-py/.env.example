# Copy this file to ".env" and fill in your own values.
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT="https://ai-103-demos-resource.services.ai.azure.com/api/projects/ai-103-demos"

# Name of the published workflow in your Foundry project (must match exactly).
WORKFLOW_NAME="Contoso-Job-Application-Triage"

# Model deployment used by the workflow's agents (e.g. gpt-5.4).
MODEL_DEPLOYMENT_NAME="gpt-5.4"
